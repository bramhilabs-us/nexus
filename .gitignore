# Secrets — never commit
.env
.env.*
!.env.example
!.env.production.example
*.pem
*.key
secrets/

# Mongo connection strings sometimes leak into temp files
*.mongo.tmp

# Agent runtime state (per-day, per-tick artifacts — ephemeral)
_agent/.budget-*.tally
_agent/.tick-events.log
_agent/.tmp/

# Audit reports (dated, can regenerate)
_agent/AUDIT_*.md

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Node (Night 2+)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.backup

# Build artifacts
dist/
build/
.next/
.nuxt/
coverage/

# Logs
logs/
*.log

# Test artifacts
test-results/
playwright-report/
.nyc_output/

# Settings local overrides
.claude/settings.local.json
