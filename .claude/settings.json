      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh auth status:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(touch:*)",
      "Bash(date:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(jq:*)",
      "Bash(mkdir:*)",
      "Bash(sips:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(pnpm:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(cd:*)",
      "Read(*)",
      "Write(/Users/sagarrs/Desktop/Official Dev/nexus/**)",
      "Edit(/Users/sagarrs/Desktop/Official Dev/nexus/**)"
    ],
    "deny": [
      "Write(/Users/sagarrs/Desktop/official_dev/karvia_business/**)",
      "Edit(/Users/sagarrs/Desktop/official_dev/karvia_business/**)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/sagarrs/Desktop/Official Dev/nexus/.claude/hooks/guard-karvia.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/sagarrs/Desktop/Official Dev/nexus/.claude/hooks/budget-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/sagarrs/Desktop/Official Dev/nexus/.claude/hooks/tick-end.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "NEXUS_DAILY_BUDGET_USD": "60",
    "NEXUS_AUTONOMY_LEVEL": "0",
    "NEXUS_REPO": "bramhilabs-us/nexus",
    "NEXUS_KARVIA_REFERENCE": "/Users/sagarrs/Desktop/official_dev/karvia_business"
